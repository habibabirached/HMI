# Environment variables loaded by docker-compose up command, in particular used by the docker-compose-dev.yml file
# you can achieve the same effect by modifying the ~/.docker/config.json file
PROXY_HOST=proxy.research.ge.com
PROXY=http://proxy.research.ge.com:80
HTTP_PROXY=http://proxy.research.ge.com:80
HTTPS_PROXY=http://proxy.research.ge.com:80
NO_PROXY=localhost,127.0.0.1,.ge.com,.build.ge.com,github.build.ge.com,bdc_srv,bdc_measurement,bdc_s3_access,bdc_ui
http_proxy=http://proxy.research.ge.com:80
https_proxy=http://proxy.research.ge.com:80
no_proxy=localhost,127.0.0.1,.ge.com,.build.ge.com,github.build.ge.com,bdc_srv,bdc_measurement,bdc_s3_access,bdc_ui

# This is for running jenkins in the server and keeping uid:gid on volumes compatible with roberto's user
#UID=212336564
#GID=99999999