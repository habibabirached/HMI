# ============================================================================
# ENVIRONMENT VARIABLES - Example Configuration
# ============================================================================
# This is a TEMPLATE file showing which environment variables the backend needs.
# Copy this to .env and fill in your actual values.
#
# TO USE:
#   cp .env.example .env
#   nano .env  (edit with your values)
#
# The .env file is loaded by python-dotenv and provides configuration
# without hardcoding values in the code.
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------
# For SQLite (simple, file-based - good for development):
DATABASE_URL=sqlite:///./datacenter.db

# For PostgreSQL (production-grade - if you want to use it instead):
# DATABASE_URL=postgresql://user:password@localhost:5432/datacenter

# ----------------------------------------------------------------------------
# SERVER CONFIGURATION
# ----------------------------------------------------------------------------
# Port the backend server listens on
PORT=5000

# Host to bind to (0.0.0.0 means all network interfaces)
HOST=0.0.0.0

# ----------------------------------------------------------------------------
# STORAGE CONFIGURATION
# ----------------------------------------------------------------------------
# Directory where configuration files are saved to disk
SAVED_CONFIGS_DIR=/app/saved_configs

# Maximum file size for uploads (in MB)
MAX_UPLOAD_SIZE_MB=10

# ----------------------------------------------------------------------------
# CORS CONFIGURATION
# ----------------------------------------------------------------------------
# Which frontend URLs are allowed to call this backend
# In development, we allow all origins (*)
# In production, specify the exact frontend URL
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# ----------------------------------------------------------------------------
# APPLICATION SETTINGS
# ----------------------------------------------------------------------------
# Environment: development or production
ENVIRONMENT=development

# Enable debug mode (verbose logging)
DEBUG=True
